Screen {
    background: $surface;
}

#side-context {
    width: 40;
    dock: left;
    background: $panel;
    border-right: solid $primary;
    display: none;
}

#context-header {
    padding: 1 2;
    background: $primary-darken-1;
    color: $text;
    text-style: bold;
    width: 100%;
    opacity: 0.6;
}

#context-list {
    background: transparent;
}

ContextFragmentItem {
    padding: 0 1;
}

ContextFragmentItem Label {
    width: 100%;
}

#side-tasklist {
    width: 30;
    dock: right;
    background: $panel;
    border-left: solid $primary;
    display: none;
}

#tasklist-header {
    padding: 1 2;
    background: $primary-darken-1;
    color: $text;
    text-style: bold;
    width: 100%;
}

#tasklist-container {
    padding: 1 2;
}

#tasklist-content {
    width: 100%;
}

ChatPanel {
    height: 1fr;
    width: 1fr;
}

#chat-log {
    height: 1fr;
    border: none;
    background: $surface;
}

#chat-spinner-area {
    height: 1;
    margin: 0 2;
    layout: horizontal;
    /* Ensure the area doesn't collapse if children are hidden */
    min-height: 1;
}

#chat-spinner {
    height: 1;
    width: auto;
    min-width: 4;
    background: transparent;
    color: $accent;
}

#chat-timer {
    height: 1;
    width: auto;
    content-align: left middle;
}

.token-usage {
    width: 1fr;
    height: 1;
    content-align: right middle;
    color: $text-disabled;
}

#chat-input {
    margin: 1 2;
    border: solid $primary;
    height: 4;
}

#notification-panel {
    height: 4;
    margin: 0 2;
    background: $panel;
    border: solid $primary-darken-2;
}

.hidden {
    display: none;
}

#chat-input:focus {
    border: solid $accent;
}

.ml-1 {
    margin-left: 1;
}
