Screen {
    background: $surface;
}

ContextModalScreen, TaskListModalScreen, SessionCostsModalScreen, DependenciesModalScreen, CommandsModalScreen {
    align: center middle;
}

#dependencies-modal-container {
    width: 100%;
    height: 100%;
    padding: 1 2;
    background: $surface;
}

#dependencies-status {
    height: auto;
    color: $accent;
    text-style: bold;
}

#dependencies-spinner {
    height: 1;
    color: $accent;
}

AddDependencyModalScreen {
    align: center middle;
}

#add-dependency-modal-container {
    width: 80;
    height: auto;
    max-height: 80%;
    background: $surface;
    border: thick $primary;
    padding: 1 2;
}

#add-dependency-title {
    text-style: bold;
    width: 100%;
    margin-bottom: 1;
}

#add-dependency-mode-select {
    height: auto;
    margin-bottom: 1;
}

#add-dependency-local-section,
#add-dependency-git-section {
    height: auto;
}

#add-dependency-repo-row {
    height: auto;
}

#add-dependency-repo-row Input {
    width: 1fr;
}

#add-dependency-repo-row Button {
    width: auto;
    min-width: 10;
}

#add-dependency-fetch-spinner {
    height: 1;
    color: $accent;
}

#add-dependency-branch-list {
    height: auto;
    max-height: 10;
}

#add-dependency-error {
    color: $error;
    height: auto;
}

#add-dependency-actions {
    height: auto;
    margin-top: 1;
}

BrokkApiKeyModalScreen, TaskTitleModalScreen, ModelReasoningSelectModal {
    align: center middle;
}

#context-modal-container {
    width: 100%;
    height: 100%;
    padding: 1 2;
    background: $surface;
}

#tasklist-modal-container {
    width: 100%;
    height: 100%;
    padding: 1 2;
    background: $surface;
}

#session-costs-container {
    width: 100%;
    height: 100%;
    padding: 1 2;
    background: $surface;
}

#task-title-modal-container {
    width: 60;
    height: auto;
    max-height: 80%;
    border: thick $primary;
    background: $surface;
    padding: 1 2;
    align: center middle;
}

#task-title-modal-title {
    text-align: center;
    width: 100%;
    text-style: bold;
    margin-bottom: 1;
    color: $text;
}

#task-title-input {
    width: 1fr;
}

#side-tasklist {
    width: 38;
    dock: right;
    background: $panel;
    border-left: solid $primary;
    display: none;
}

#side-tasklist:focus {
    /* When the task list panel has keyboard focus, highlight with the accent color
       to match other focused elements like #chat-input and .context-chip. */
    border-left: solid $accent;
}

#tasklist-header {
    padding: 1 2;
    background: $primary-darken-1;
    color: $text;
    text-style: bold;
    width: 100%;
}

#tasklist-container {
    padding: 1 2;
}

#tasklist-selection {
    width: 100%;
    color: $text-disabled;
    padding: 0 2;
}

#tasklist-help-line {
    width: 100%;
    height: 1;
    color: $text-disabled;
    background: transparent;
    margin-bottom: 1;
    padding: 0 1;
}

#tasklist-content {
    width: 100%;
}

ChatPanel {
    height: 1fr;
    width: 1fr;
}

#chat-log {
    height: 1fr;
    min-width: 0;
    border: none;
    background: $surface;
    overflow-x: hidden;
    scrollbar-size-horizontal: 0;
}

#scroll-to-bottom {
    width: auto;
    min-width: 0;
    height: 1;
    margin: 0 1 0 0;
    padding: 0 1;
    background: $primary;
    color: $text;
    border: none;
    text-style: bold;
}

#scroll-to-bottom:hover {
    background: $primary-lighten-1;
}

#scroll-to-bottom:focus {
    background: $primary-lighten-1;
}



#help-elapsed {
    width: auto;
    min-width: 17;
    height: 1;
    color: $text-disabled;
    background: transparent;
    margin-right: 1;
}

#chat-token-bar {
    width: 1fr;
    height: 1;
    margin: 0 2 1 2;
    content-align: right middle;
}

#context-panel {
    margin: 0;
    height: 1fr;
    max-height: 100%;
    width: 100%;
    background: $panel;
    border: solid $primary-darken-2;
    padding: 0 1;
}

#context-header {
    height: 1;
    width: 100%;
    layout: horizontal;
    margin: 0;
}

#context-title {
    text-style: bold;
    color: $text;
    width: auto;
}

#context-token-usage {
    width: 1fr;
    content-align: right middle;
    color: $text-disabled;
}

#context-selection-status {
    width: 100%;
    color: $text-disabled;
}

#context-selection-status.has-selection {
    color: $warning;
    text-style: bold;
}

#context-active-status {
    width: 100%;
    color: $text-disabled;
}

#context-active-status.has-active {
    color: $accent;
    text-style: bold;
}

#context-help-line {
    width: 100%;
    height: 1;
    color: $text-disabled;
    background: transparent;
    margin-bottom: 1;
    padding: 0 1;
}

#context-chip-scroll {
    height: 1fr;
    min-height: 3;
    width: 100%;
}

#context-chip-wrap {
    width: 100%;
    height: auto;
}

.context-chip-row {
    layout: horizontal;
    width: 100%;
    height: auto;
}

.context-chip {
    height: 3;
    width: auto;
    margin-right: 1;
    padding: 0 1;
    border: round $primary-darken-2;
    background: $surface-lighten-1;
    color: $text;
}

.context-chip:focus {
    border: round $accent;
}

.context-chip:hover {
    border: round $accent;
    background: $accent 22%;
}

.context-chip-empty {
    border: none;
    padding: 0;
    color: $text-disabled;
    background: transparent;
}

.context-chip.kind-edit {
    background: $success 15%;
    border: round $success;
    color: $success-lighten-3;
}

.context-chip.kind-summary {
    background: $accent 12%;
    border: round $accent;
}

.context-chip.kind-history {
    background: $warning 15%;
    border: round $warning;
}

.context-chip.kind-invalid {
    background: $error 15%;
    border: round $error;
}

.context-chip.kind-task-list {
    background: $primary 18%;
    border: round $primary;
}

.context-chip.is-pinned {
    text-style: bold;
}

.context-chip.is-active {
    border: round $accent-lighten-2;
    background: $accent 45%;
    color: $text;
    text-style: bold;
}

.context-chip.is-selected {
    border: round $success-lighten-2;
    background: $success 65%;
    color: $text;
    text-style: bold;
}

#chat-input-container {
    height: auto;
    width: 100%;
    layout: vertical;
}

#chat-input-container.autocomplete-open {
    /* Prompt no longer moves when autocomplete is open */
    margin-bottom: 0;
}

#chat-input {
    margin: 0 2 1 2;
    background: $panel;
    padding: 0 1;
    height: 3;
    border: none;
    content-align: left middle;
    layer: base;
}


#status-line {
    margin: 1 2 0 2;
    height: 1;
}

#status-spinner {
    display: none;
}

/* Ensure the Textual `.hidden` class continues to hide the status line cleanly. */
.hidden {
    display: none;
}

#chat-input:focus {
    background: $surface-lighten-1;
    border: none;
    content-align: left middle;
}

SlashCommandSuggestions, ModeSuggestions, ReasoningSuggestions {
    background: $panel;
    border: none;
    color: $text;
    scrollbar-gutter: stable;
    /* Overlay above the input: bottom margin 6 covers status line (1) + prompt (3) + help row (1) + gap */
    margin: 0 2 6 2;
    max-height: 20;
    width: 1fr;
    display: none;
    layer: top;
    dock: bottom;
}

SlashCommandSuggestions > ListItem:focus, ModeSuggestions > ListItem:focus, ReasoningSuggestions > ListItem:focus {
    background: $surface-lighten-1;
    color: $accent;
}

SlashCommandSuggestions ListItem, ModeSuggestions ListItem, ReasoningSuggestions ListItem {
    padding: 0 1;
}

#chat-help-row {
    height: 1;
    margin: 0 2 1 2;
}

#help-spinner {
    height: 1;
    width: auto;
    min-width: 4;
    color: $accent;
    background: transparent;
    margin-right: 1;
}

#chat-help {
    width: 1fr;
    height: 1;
    padding: 0 1;
    color: $text-disabled;
    background: transparent;
    content-align: right middle;
    text-align: right;
}

.ml-1 {
    margin-left: 1;
}

#model-select-container, #reasoning-select-container {
    width: 60;
    height: auto;
    max-height: 80%;
    border: thick $primary;
    background: $surface;
    padding: 1 2;
    align: center middle;
}

#model-reasoning-combined-container {
    width: 100;
    height: auto;
    max-height: 90%;
    border: thick $primary;
    background: $surface;
    padding: 1 2;
}

.selection-pane {
    width: 1fr;
    height: auto;
    padding: 0 1;
}

#model-select-title, #reasoning-select-title {
    text-align: center;
    width: 100%;
    text-style: bold;
    margin-bottom: 1;
    color: $text;
}

#model-select-list-wrap, #reasoning-select-list-wrap {
    height: 1fr;
    max-height: 30;
    border: tall $primary-darken-1;
}

#model-select-list, #reasoning-select-list {
    background: transparent;
    height: 1fr;
}

#model-select-list > ListItem:focus, #reasoning-select-list > ListItem:focus {
    background: $accent 20%;
    color: $text;
    text-style: bold;
}

#model-select-list > ListItem, #reasoning-select-list > ListItem {
    padding: 0 1;
}

#api-key-modal-container {
    width: 100%;
    height: 100%;
    background: $surface;
    padding: 1 2;
}

#api-key-modal-scroll {
    height: 1fr;
    margin-bottom: 1;
}

#api-key-modal-icon {
    width: 100%;
    content-align: center middle;
    color: $accent;
    margin-bottom: 1;
}

#api-key-modal-welcome {
    background: transparent;
    padding: 0 1;
}

#api-key-modal-title {
    text-align: center;
    width: 100%;
    text-style: bold;
    margin-bottom: 1;
}

#api-key-modal-spinner {
    height: 1;
    width: 100%;
    color: $accent;
    background: transparent;
    margin-bottom: 1;
}

#api-key-modal-footer {
    text-align: center;
    width: 100%;
    margin-top: 1;
    color: $text-disabled;
}

#session-costs-help-line {
    width: 100%;
    height: 1;
    color: $text-disabled;
    background: transparent;
    margin-top: 1;
    padding: 0 1;
}

#session-costs-title {
    text-align: center;
    width: 100%;
    text-style: bold;
    margin-bottom: 1;
    color: $text;
}

#session-costs-list-wrap {
    height: 1fr;
    border: tall $primary-darken-1;
    width: 100%;
}

#session-costs-list {
    width: 100%;
    height: auto;
}

#session-costs-header {
    width: 100%;
    height: 1;
    background: $primary-darken-2;
    color: $text;
    text-style: bold;
    padding: 0 1;
}

#session-costs-list > ListItem {
    width: 100%;
    height: auto;
    padding: 0;
}

#session-costs-list > ListItem:focus {
    background: $accent 15%;
}

.session-cost-row {
    width: 100%;
    height: auto;
    padding: 0 1;
}

.session-cost-row Static {
    height: auto;
}

.col-ts { width: 18; }
.col-type { width: 12; }
.col-model { width: 1fr; }
.col-label { width: 2fr; }
.col-tokens { width: 25; }
.col-cost { width: 10; content-align: right middle; }

#session-costs-summary {
    height: auto;
    margin-top: 1;
    padding: 1 2;
    background: $primary-darken-3;
    border: tall $primary-darken-1;
}

#dependencies-container {
    width: 100%;
    height: 100%;
    padding: 1 2;
}

#dependencies-title {
    padding: 1 2;
    background: $primary-darken-1;
    color: $text;
    text-style: bold;
    width: 100%;
}

#dependencies-help-line {
    width: 100%;
    height: 1;
    color: $text-disabled;
    margin-bottom: 1;
}

#dependencies-list-scroll {
    height: 1fr;
    border: tall $primary-darken-1;
}

#dependencies-list {
    background: transparent;
}

#dependencies-list > ListItem:focus {
    background: $accent 20%;
}

PrCreateModalScreen {
    align: center middle;
}

#pr-create-container {
    width: 95%;
    height: auto;
    max-height: 95%;
    border: thick $primary;
    background: $surface;
    padding: 1 1;
}

#pr-create-title {
    text-align: center;
    width: 100%;
    text-style: bold;
    margin-bottom: 1;
    color: $text;
}

#pr-create-branches {
    text-align: center;
    width: 100%;
    margin-bottom: 1;
}

#pr-title-label, #pr-body-label {
    width: 100%;
    margin-top: 1;
    color: $text;
}

#pr-title-input {
    width: 100%;
    margin-bottom: 1;
}

#pr-body-input {
    width: 100%;
    height: 12;
    margin-bottom: 1;
}

#pr-create-actions {
    width: 100%;
    height: auto;
    align: center middle;
    margin-top: 1;
}

#pr-create-actions Button {
    margin: 0 1;
}

#pr-sessions-label {
    width: 100%;
    margin-top: 1;
    color: $text;
}

#pr-sessions-scroll {
    width: 100%;
    height: 6;
    max-height: 8;
    border: tall $primary-darken-1;
    margin-bottom: 1;
}

#pr-sessions-list {
    background: transparent;
    height: auto;
}

#pr-sessions-list > ListItem {
    padding: 0 1;
}

#pr-sessions-list > ListItem:focus {
    background: $accent 20%;
    color: $text;
}

/* Settings Modal Styles */
SettingsModalScreen {
    align: center middle;
}

#settings-modal-container {
    width: 100%;
    height: 100%;
    padding: 1 2;
    background: $surface;
}

#settings-modal-title {
    text-align: center;
    width: 100%;
    text-style: bold;
    margin-bottom: 1;
    color: $text;
}

#settings-tabs {
    height: 1fr;
}

.settings-tab-scroll {
    height: 1fr;
    padding: 1 2;
}

.settings-section-title {
    text-style: bold;
    color: $accent;
    margin-top: 2;
    margin-bottom: 1;
}

.settings-subsection-label {
    margin-top: 1;
    color: $text;
}

.settings-hint {
    color: $text-disabled;
    margin-bottom: 1;
}

.settings-list-actions {
    height: auto;
    margin-top: 1;
    margin-bottom: 1;
}

.settings-list-actions Button {
    margin-right: 1;
}

#settings-exclusion-list {
    height: 6;
    max-height: 8;
    border: tall $primary-darken-1;
    background: transparent;
}

#settings-exclusion-list > ListItem {
    padding: 0 1;
}

#settings-exclusion-list > ListItem:focus {
    background: $accent 20%;
}

#settings-commit-format {
    height: 5;
    margin-bottom: 1;
}

#settings-modules-table {
    height: 8;
    max-height: 12;
    border: tall $primary-darken-1;
    background: transparent;
}

/* Issue Provider Section */
#settings-issue-provider-select {
    height: auto;
    margin-bottom: 1;
}

#settings-issue-provider-select Button {
    margin-right: 1;
}

#settings-issue-none-section,
#settings-issue-github-section,
#settings-issue-jira-section {
    height: auto;
    margin-bottom: 1;
    padding: 0 1;
}

#settings-issue-none-text {
    color: $text-disabled;
}

#settings-github-fields {
    height: auto;
    margin-top: 1;
}

/* Module Edit Modal */
ModuleEditModalScreen {
    align: center middle;
}

#module-edit-modal-container {
    width: 70;
    height: auto;
    max-height: 90%;
    border: thick $primary;
    background: $surface;
    padding: 1 2;
}

#module-edit-modal-title {
    text-align: center;
    width: 100%;
    text-style: bold;
    margin-bottom: 1;
    color: $text;
}

.module-edit-label {
    margin-top: 1;
    color: $text;
}

#module-edit-modal-actions {
    width: 100%;
    height: auto;
    margin-top: 1;
}

#module-edit-modal-actions Button {
    margin-right: 1;
}

.settings-row {
    height: auto;
    width: 100%;
    margin-bottom: 1;
}

.settings-label {
    width: 25;
    height: auto;
    padding-right: 1;
}

.settings-row Input {
    width: 1fr;
}

.settings-row Checkbox {
    width: auto;
    margin-left: 1;
}

.settings-row RadioSet {
    width: 1fr;
    height: auto;
    layout: horizontal;
}

.settings-row RadioButton {
    width: auto;
    margin-right: 2;
}

#settings-error {
    height: auto;
    color: $error;
    margin-top: 1;
}

#settings-modal-actions {
    width: 100%;
    height: auto;
    align: center middle;
    margin-top: 1;
}

#settings-modal-actions Button {
    margin: 0 1;
}

#settings-languages-scroll {
    height: 8;
    max-height: 12;
    border: tall $primary-darken-1;
    background: transparent;
    padding: 0 1;
}

#settings-languages-scroll Checkbox {
    height: auto;
    margin: 0;
    padding: 0;
}

/* Commands Modal Styles */
#commands-modal-container {
    width: 100%;
    height: 100%;
    padding: 1 2;
    background: $surface;
}

#commands-modal-title {
    text-align: center;
    width: 100%;
    text-style: bold;
    margin-bottom: 1;
    color: $text;
}

#commands-list-wrap {
    height: 1fr;
    border: tall $primary-darken-1;
    width: 100%;
}

#commands-list {
    width: 100%;
    height: auto;
}

#commands-header {
    width: 100%;
    height: 1;
    background: $primary-darken-2;
    color: $text;
    text-style: bold;
    padding: 0 1;
}

#commands-list > ListItem {
    width: 100%;
    height: auto;
    padding: 0;
}

#commands-list > ListItem:focus {
    background: $accent 15%;
}

.command-row {
    width: 100%;
    height: auto;
    padding: 0 1;
}

.command-row Static {
    height: auto;
}

.cmd-col-time { width: 10; }
.cmd-col-stage { width: 15; }
.cmd-col-command { width: 1fr; }
.cmd-col-status { width: 8; content-align: right middle; }

#commands-output-panel {
    width: 100%;
    height: auto;
    max-height: 12;
    padding: 1 2;
    margin-top: 1;
    background: $primary-darken-3;
    border: tall $primary-darken-1;
    overflow-y: auto;
}

#commands-summary {
    height: auto;
    margin-top: 1;
    padding: 1 2;
    background: $primary-darken-3;
    border: tall $primary-darken-1;
}

#commands-help-line {
    width: 100%;
    height: 1;
    color: $text-disabled;
    background: transparent;
    margin-top: 1;
    padding: 0 1;
}

#commands-empty {
    color: $text-disabled;
    padding: 1 2;
}
